   "outputs": [],
   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 11 — Build Gallery from Dataset\n",
    "#\n",
    "# Expected folder layout:\n",
    "#   dataset/\n",
    "#     Alice/\n",
    "#       img1.jpg  img2.jpg  ...  (more photos = better accuracy)\n",
    "#     Bob/\n",
    "#       img1.jpg  ...\n",
    "#\n",
    "# 5+ photos per person is ideal. 2 works but 5+ is much more robust.\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def process_one_image(img_path: Path) -> Optional[np.ndarray]:\n",
    "    \"\"\"Detect → align → return aligned face. Returns None on failure.\"\"\"\n",
    "    bgr  = cv2.imread(str(img_path))\n",
    "    if bgr is None:\n",
    "        return None\n",
    "\n",
    "    faces = detector.detect(bgr)\n",
    "    if not faces:\n",
    "        return None\n",
    "\n",
    "    # Use the largest detected face\n",
    "    best_det = max(faces, key=lambda d: d[\"box\"][2] * d[\"box\"][3])\n",
    "    return aligner.align(bgr, best_det)\n",
    "\n",
    "\n",
    "def build_gallery(dataset_path: Path, use_augmentation: bool = True):\n",
    "    \"\"\"\n",
    "    Reads every student folder, extracts embeddings, averages them,\n",
    "    and registers each person in the gallery.\n",
    "    \"\"\"\n",
    "    dataset_path = Path(dataset_path)\n",
    "    person_dirs  = sorted([d for d in dataset_path.iterdir() if d.is_dir()])\n",
    "\n",
    "    if not person_dirs:\n",
    "        raise FileNotFoundError(f\"No sub-folders found in {dataset_path}\")\n",
    "\n",
    "    log.info(f\"Building gallery for {len(person_dirs)} people ...\")\n",
    "    overall_stats = {\"registered\": 0, \"skipped\": 0}\n",
    "\n",
    "    for person_dir in tqdm(person_dirs, desc=\"Processing people\"):\n",
    "        name = person_dir.name\n",
    "        image_files = sorted([\n",
    "            f for f in person_dir.iterdir()\n",
    "            if f.suffix.lower() in (\".jpg\", \".jpeg\", \".png\", \".bmp\", \".webp\")\n",
    "        ])\n",
    "\n",
    "        if not image_files:\n",
    "            log.warning(f\"  {name}: no images found — skipping\")\n",
    "            overall_stats[\"skipped\"] += 1\n",
    "            continue\n",
    "\n",
    "        all_embeddings = []\n",
    "        good, bad = 0, 0\n",
    "\n",
    "        for img_path in image_files:\n",
    "            aligned = process_one_image(img_path)\n",
    "            if aligned is None:\n",
    "                bad += 1\n",
    "                continue\n",
    "\n",
    "            variants = augment(aligned) if use_augmentation else [aligned]\n",
    "            for v in variants:\n",
    "                all_embeddings.append(extractor.get_embedding(v))\n",
    "            good += 1\n",
    "\n",
    "        if not all_embeddings:\n",
    "            log.warning(f\"  {name}: no usable faces detected — skipping\")\n",
    "            overall_stats[\"skipped\"] += 1\n",
    "            continue\n",
    "\n",
    "        gallery.register(name, all_embeddings)\n",
    "        overall_stats[\"registered\"] += 1\n",
    "        log.info(f\"  {name}: {good} photos → {len(all_embeddings)} embeddings  ({bad} skipped)\")\n",
    "\n",
    "    # Save the gallery to Drive\n",
    "    gallery.save(cfg.EMBEDDINGS_SAVE)\n",
    "\n",
    "    print(f\"\\n✅  Gallery built!\")\n",
    "    print(f\"   Registered: {overall_stats['registered']} people\")\n",
    "    print(f\"   Skipped:    {overall_stats['skipped']} people\")\n",
    "    print(f\"   Saved to:   {cfg.EMBEDDINGS_SAVE}\")\n",
    "\n",
    "\n",
    "# ── Run ──────────────────────────────────────────────────────────\n",
    "build_gallery(cfg.DATASET_PATH, use_augmentation=cfg.AUGMENT)"
   ]
  },
