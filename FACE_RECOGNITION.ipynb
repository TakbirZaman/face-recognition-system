   "metadata": {},
   "outputs": [],
   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 7 — FaceAligner  (landmark-based affine alignment)\n",
    "#\n",
    "# Why alignment matters:\n",
    "#   Deep embedding models expect a canonical face pose.\n",
    "#   SFace was trained on 112×112 faces aligned so both eyes\n",
    "#   sit at fixed pixel coordinates. Without this step accuracy\n",
    "#   drops noticeably on tilted or off-centre faces.\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "class FaceAligner:\n",
    "    \"\"\"\n",
    "    Produces a 112×112 aligned, CLAHE-enhanced face crop.\n",
    "    This is the exact input format SFace was trained on.\n",
    "\n",
    "    Landmark indices from YuNet:\n",
    "        0 = right eye\n",
    "        1 = left eye\n",
    "        2 = nose tip\n",
    "        3 = right mouth corner\n",
    "        4 = left mouth corner\n",
    "\n",
    "    Reference eye positions (from the SFace paper / ArcFace convention):\n",
    "        right eye → (30.2946, 51.6963)\n",
    "        left eye  → (65.5318, 51.5014)\n",
    "    \"\"\"\n",
    "\n",
    "    OUTPUT_SIZE = (112, 112)\n",
    "\n",
    "    # ArcFace / SFace canonical landmark positions for 112×112\n",
    "    _REF_PTS = np.array([\n",
    "        [30.2946, 51.6963],   # right eye\n",
    "        [65.5318, 51.5014],   # left eye\n",
    "        [48.0252, 71.7366],   # nose\n",
    "        [33.5493, 92.3655],   # right mouth\n",
    "        [62.7299, 92.2041],   # left mouth\n",
    "    ], dtype=np.float32)\n",
    "\n",
    "    def __init__(self):\n",
    "        self._clahe = cv2.createCLAHE(clipLimit=2.0, tileGridSize=(8, 8))\n",
    "\n",
    "    def align(self, bgr: np.ndarray, detection: dict) -> Optional[np.ndarray]:\n",
    "        \"\"\"\n",
    "        Returns an aligned 112×112 BGR face, or None if the crop is too small.\n",
    "        SFace works in BGR, so we do NOT convert to gray here.\n",
    "        \"\"\"\n",
    "        if detection[\"landmarks\"] is not None:\n",
    "            return self._landmark_align(bgr, detection[\"landmarks\"])\n",
    "        else:\n",
    "            return self._simple_crop(bgr, detection[\"box\"])\n",
    "\n",
    "    def _landmark_align(self, bgr: np.ndarray, landmarks: np.ndarray) -> Optional[np.ndarray]:\n",
    "        src = landmarks.astype(np.float32)          # 5×2\n",
    "        dst = self._REF_PTS                         # 5×2\n",
    "\n",
    "        # Estimate similarity transform (rotation + scale + translation)\n",
    "        M, _ = cv2.estimateAffinePartial2D(src, dst, method=cv2.LMEDS)\n",
    "        if M is None:\n",
    "            return None\n",
    "\n",
    "        aligned = cv2.warpAffine(bgr, M, self.OUTPUT_SIZE,\n",
    "                                 flags=cv2.INTER_CUBIC,\n",
    "                                 borderMode=cv2.BORDER_REPLICATE)\n",
    "        return self._clahe_enhance(aligned)\n",
    "\n",
    "    def _simple_crop(self, bgr: np.ndarray, box: list) -> Optional[np.ndarray]:\n",
    "        x, y, w, h = box\n",
    "        ih, iw = bgr.shape[:2]\n",
    "        x, y   = max(0, x), max(0, y)\n",
    "        w      = min(w, iw - x)\n",
    "        h      = min(h, ih - y)\n",
    "        if w < 30 or h < 30:\n",
    "            return None\n",
    "        crop = bgr[y:y+h, x:x+w]\n",
    "        crop = cv2.resize(crop, self.OUTPUT_SIZE)\n",
    "        return self._clahe_enhance(crop)\n",
    "\n",
    "    def _clahe_enhance(self, bgr: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"Apply CLAHE per channel (keeps colour for SFace, improves contrast).\"\"\"\n",
    "        lab = cv2.cvtColor(bgr, cv2.COLOR_BGR2LAB)\n",
    "        l, a, b = cv2.split(lab)\n",
    "        l_eq = self._clahe.apply(l)\n",
    "        lab_eq = cv2.merge([l_eq, a, b])\n",
    "        return cv2.cvtColor(lab_eq, cv2.COLOR_LAB2BGR)\n",
    "\n",
    "\n",
    "aligner = FaceAligner()\n",
    "print(\"✅  FaceAligner ready  (112×112 landmark alignment + CLAHE)\")"
   ]
  },
  {
   "cell_type": "code",
