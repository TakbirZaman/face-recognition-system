   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 14 — Visualiser helper\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def draw_detections(bgr: np.ndarray, faces: list, results: list) -> np.ndarray:\n",
    "    \"\"\"\n",
    "    Draws bounding boxes, landmark dots, and identity labels on the image.\n",
    "\n",
    "    Green box + name  = confident match\n",
    "    Red box + Unknown = no match above threshold\n",
    "    \"\"\"\n",
    "    img = bgr.copy()\n",
    "\n",
    "    for det, res in zip(faces, results):\n",
    "        x, y, w, h = det[\"box\"]\n",
    "        confident   = res[\"confident\"]\n",
    "        name        = res[\"name\"]\n",
    "        sim         = res[\"similarity\"]\n",
    "\n",
    "        color = (0, 210, 0) if confident else (0, 0, 220)\n",
    "\n",
    "        # Bounding box\n",
    "        cv2.rectangle(img, (x, y), (x+w, y+h), color, 2)\n",
    "\n",
    "        # Label background for readability\n",
    "        label = f\"{name}  {sim:.2f}\"\n",
    "        (tw, th), _ = cv2.getTextSize(label, cv2.FONT_HERSHEY_DUPLEX, 0.65, 1)\n",
    "        cv2.rectangle(img, (x, y - th - 10), (x + tw + 6, y), color, -1)\n",
    "        cv2.putText(img, label, (x + 3, y - 5),\n",
    "                    cv2.FONT_HERSHEY_DUPLEX, 0.65, (255, 255, 255), 1)\n",
    "\n",
    "        # Landmark dots (only if YuNet gave us landmarks)\n",
    "        if det[\"landmarks\"] is not None:\n",
    "            for lm_x, lm_y in det[\"landmarks\"].astype(int):\n",
    "                cv2.circle(img, (lm_x, lm_y), 3, (0, 255, 255), -1)\n",
    "\n",
    "    return img\n",
    "\n",
    "print(\"✅  Visualiser ready\")"
   ]
  },
