   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 15 — Recognise: From Webcam  ← the main use case\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def recognise_from_webcam(show_top_k: bool = False):\n",
    "    \"\"\"\n",
    "    Captures a photo from the webcam and runs full face recognition.\n",
    "\n",
    "    show_top_k = True  → print the top-3 candidates for each face\n",
    "                         (helpful for debugging threshold tuning)\n",
    "    \"\"\"\n",
    "    print(\"📷  Opening camera — look at the camera and stay still ...\")\n",
    "    bgr = capture_frame(\"/content/query.jpg\")\n",
    "    if bgr is None:\n",
    "        print(\"❌  Could not capture image.\")\n",
    "        return\n",
    "\n",
    "    # ── Detection ─────────────────────────────────────────────────\n",
    "    faces = detector.detect(bgr)\n",
    "    if not faces:\n",
    "        print(\"❌  No face detected. Make sure your face is visible and well-lit.\")\n",
    "        cv2_imshow(bgr)\n",
    "        return\n",
    "\n",
    "    print(f\"   {len(faces)} face(s) detected.\")\n",
    "\n",
    "    # ── Recognition ───────────────────────────────────────────────\n",
    "    results = []\n",
    "    for i, det in enumerate(faces):\n",
    "        aligned = aligner.align(bgr, det)\n",
    "        if aligned is None:\n",
    "            results.append({\"name\": \"Unknown\", \"similarity\": 0.0, \"confident\": False})\n",
    "            continue\n",
    "\n",
    "        query_vec = extractor.get_embedding(aligned)\n",
    "        result    = gallery.identify(query_vec)\n",
    "        results.append(result)\n",
    "\n",
    "        tag = \"✅\" if result[\"confident\"] else \"❓\"\n",
    "        print(f\"   Face {i+1}: {tag}  {result['name']}  (similarity = {result['similarity']:.4f})\")\n",
    "\n",
    "        if show_top_k:\n",
    "            ranking = gallery.identify_with_ranking(query_vec, top_k=3)\n",
    "            for rank_i, candidate in enumerate(ranking):\n",
    "                print(f\"          #{rank_i+1}  {candidate['name']}  →  {candidate['similarity']:.4f}\")\n",
    "\n",
    "    # ── Draw + display ────────────────────────────────────────────\n",
    "    annotated = draw_detections(bgr, faces, results)\n",
    "    cv2_imshow(annotated)\n",
    "\n",
    "\n",
    "# ── Run ──────────────────────────────────────────────────────────\n",
    "recognise_from_webcam(show_top_k=True)"
   ]
  },
