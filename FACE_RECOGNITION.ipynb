   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 16 — Recognise: From Image File\n",
    "# Upload a photo and run recognition on it.\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def recognise_from_file(image_path: str, show_top_k: bool = False):\n",
    "    \"\"\"\n",
    "    Runs face recognition on an image file (not webcam).\n",
    "    Useful for testing or batch processing.\n",
    "    \"\"\"\n",
    "    bgr = cv2.imread(image_path)\n",
    "    if bgr is None:\n",
    "        print(f\"❌  Cannot read image at {image_path}\")\n",
    "        return\n",
    "\n",
    "    faces = detector.detect(bgr)\n",
    "    if not faces:\n",
    "        print(\"❌  No face detected in the image.\")\n",
    "        cv2_imshow(bgr)\n",
    "        return\n",
    "\n",
    "    print(f\"   {len(faces)} face(s) detected in {Path(image_path).name}\")\n",
    "\n",
    "    results = []\n",
    "    for i, det in enumerate(faces):\n",
    "        aligned = aligner.align(bgr, det)\n",
    "        if aligned is None:\n",
    "            results.append({\"name\": \"Unknown\", \"similarity\": 0.0, \"confident\": False})\n",
    "            continue\n",
    "\n",
    "        query_vec = extractor.get_embedding(aligned)\n",
    "        result    = gallery.identify(query_vec)\n",
    "        results.append(result)\n",
    "\n",
    "        tag = \"✅\" if result[\"confident\"] else \"❓\"\n",
    "        print(f\"   Face {i+1}: {tag}  {result['name']}  (similarity = {result['similarity']:.4f})\")\n",
    "\n",
    "        if show_top_k:\n",
    "            ranking = gallery.identify_with_ranking(query_vec, top_k=3)\n",
    "            for rank_i, candidate in enumerate(ranking):\n",
    "                print(f\"          #{rank_i+1}  {candidate['name']}  →  {candidate['similarity']:.4f}\")\n",
    "\n",
    "    annotated = draw_detections(bgr, faces, results)\n",
    "    cv2_imshow(annotated)\n",
    "\n",
    "\n",
    "# Example:\n",
    "# recognise_from_file(\"/content/drive/MyDrive/test_photo.jpg\", show_top_k=True)"
   ]
  },
  {
