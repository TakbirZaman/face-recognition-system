   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 10 — Augmentation helpers\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def augment(face_bgr: np.ndarray) -> list:\n",
    "    \"\"\"\n",
    "    Returns 6 variants of a face: original + flip + 2 brightness + noise + blur.\n",
    "    All are 112×112 BGR — same format as the input.\n",
    "    \"\"\"\n",
    "    out = [face_bgr]\n",
    "\n",
    "    # Horizontal flip (covers faces looking slightly left/right)\n",
    "    out.append(cv2.flip(face_bgr, 1))\n",
    "\n",
    "    # Brightness shifts (simulate different room lighting)\n",
    "    for shift in (-35, +35):\n",
    "        shifted = np.clip(face_bgr.astype(np.int16) + shift, 0, 255).astype(np.uint8)\n",
    "        out.append(shifted)\n",
    "\n",
    "    # Mild Gaussian noise (simulate camera sensor noise)\n",
    "    noise   = np.random.normal(0, 7, face_bgr.shape).astype(np.int16)\n",
    "    noisy   = np.clip(face_bgr.astype(np.int16) + noise, 0, 255).astype(np.uint8)\n",
    "    out.append(noisy)\n",
    "\n",
    "    # Mild Gaussian blur (simulate slight out-of-focus)\n",
    "    out.append(cv2.GaussianBlur(face_bgr, (3, 3), 0.5))\n",
    "\n",
    "    return out  # 6 total\n",
    "\n",
    "print(\"✅  Augmentation helper ready  (6 variants per image)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
