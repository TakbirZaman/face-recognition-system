   "outputs": [],
   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 17 — Threshold Calibration Tool\n",
    "#\n",
    "# Run this if you're unsure what COSINE_THRESHOLD to use.\n",
    "# It tests every image in your dataset against the gallery and\n",
    "# reports what threshold gives you the cleanest true/false split.\n",
    "#\n",
    "# Ideal scenario: all same-person pairs score >> threshold,\n",
    "#                 all different-person pairs score << threshold.\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def calibrate_threshold(dataset_path: Path, sample_limit: int = 5):\n",
    "    \"\"\"\n",
    "    For each person, runs recognition on their own photos and reports\n",
    "    the similarity scores. Lower scores than expected → raise threshold.\n",
    "    Higher scores for impostors → lower threshold.\n",
    "\n",
    "    sample_limit: max photos to test per person (keep it small for speed)\n",
    "    \"\"\"\n",
    "    print(\"🔧  Running threshold calibration ...\\n\")\n",
    "    rows = []\n",
    "\n",
    "    for person_dir in sorted(Path(dataset_path).iterdir()):\n",
    "        if not person_dir.is_dir():\n",
    "            continue\n",
    "        name = person_dir.name\n",
    "        files = sorted([\n",
    "            f for f in person_dir.iterdir()\n",
    "            if f.suffix.lower() in (\".jpg\", \".jpeg\", \".png\", \".bmp\")\n",
    "        ])[:sample_limit]\n",
    "\n",
    "        for img_path in files:\n",
    "            aligned = process_one_image(img_path)\n",
    "            if aligned is None:\n",
    "                continue\n",
    "            vec    = extractor.get_embedding(aligned)\n",
    "            result = gallery.identify_with_ranking(vec, top_k=1)\n",
    "            if not result:\n",
    "                continue\n",
    "            top    = result[0]\n",
    "            match  = top[\"name\"] == name\n",
    "            rows.append({\n",
    "                \"True Person\":  name,\n",
    "                \"Predicted\":    top[\"name\"],\n",
    "                \"Similarity\":   round(top[\"similarity\"], 4),\n",
    "                \"Correct\":      \"✅\" if match else \"❌\"\n",
    "            })\n",
    "\n",
    "    df = pd.DataFrame(rows)\n",
    "    print(df.to_string(index=False))\n",
    "\n",
    "    correct = sum(1 for r in rows if r[\"Predicted\"] == r[\"True Person\"])\n",
    "    total   = len(rows)\n",
    "    print(f\"\\n   Self-recognition accuracy: {correct}/{total}  ({100*correct/total:.1f}%)\")\n",
    "    print(f\"   Current threshold: {cfg.COSINE_THRESHOLD}\")\n",
    "    sims = [r[\"Similarity\"] for r in rows]\n",
    "    print(f\"   Similarity range on self-test: {min(sims):.3f} – {max(sims):.3f}\")\n",
    "    print(\"\\n   If correct matches score below threshold, lower COSINE_THRESHOLD.\")\n",
    "    print(\"   If wrong people match, raise COSINE_THRESHOLD.\")\n",
    "\n",
    "\n",
    "# ── Run calibration ───────────────────────────────────────────────\n",
    "calibrate_threshold(cfg.DATASET_PATH)"
   ]
  }
 ]\n}\n"
