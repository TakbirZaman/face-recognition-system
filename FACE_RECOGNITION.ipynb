   "metadata": {},
   "outputs": [],
   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 8 — EmbeddingExtractor  (SFace DNN wrapper)\n",
    "#\n",
    "# SFace produces a 128-dim L2-normalised vector per face.\n",
    "# Comparing two vectors with cosine similarity gives a score\n",
    "# from 0 (completely different) to 1 (identical).\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "class EmbeddingExtractor:\n",
    "    \"\"\"\n",
    "    Wraps OpenCV's SFace recogniser to extract 128-dim face embeddings.\n",
    "\n",
    "    The model expects a 112×112 BGR image (what FaceAligner produces).\n",
    "    Output is an L2-normalised vector, so cosine similarity = dot product.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, model_path: str):\n",
    "        self._sface = cv2.FaceRecognizerSF.create(\n",
    "            model   = model_path,\n",
    "            config  = \"\"\n",
    "        )\n",
    "        log.info(\"SFace embedding extractor ready\")\n",
    "\n",
    "    def get_embedding(self, aligned_bgr: np.ndarray) -> np.ndarray:\n",
    "        \"\"\"\n",
    "        Takes an aligned 112×112 BGR face.\n",
    "        Returns a (128,) float32 unit vector.\n",
    "        \"\"\"\n",
    "        feat = self._sface.feature(aligned_bgr)   # shape (1, 128)\n",
    "        vec  = feat.flatten().astype(np.float32)\n",
    "        # Ensure L2 normalisation (SFace already does this, but be safe)\n",
    "        norm = np.linalg.norm(vec)\n",
    "        return vec / (norm + 1e-10)\n",
    "\n",
    "    def cosine_sim(self, v1: np.ndarray, v2: np.ndarray) -> float:\n",
    "        \"\"\"Cosine similarity between two unit vectors. Range [−1, 1].\"\"\"\n",
    "        return float(np.dot(v1, v2))\n",
    "\n",
    "\n",
    "extractor = EmbeddingExtractor(cfg.SFACE_PATH)\n",
    "print(\"✅  EmbeddingExtractor (SFace) ready\")"
   ]
  },
  {
   "cell_type": "code",
