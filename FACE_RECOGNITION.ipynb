    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 5 — Download DNN Models\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "def download(url: str, dest: str, name: str):\n",
    "    \"\"\"Download only if the file doesn't already exist.\"\"\"\n",
    "    if Path(dest).exists():\n",
    "        log.info(f\"{name} already cached at {dest}\")\n",
    "        return\n",
    "    log.info(f\"Downloading {name} ...\")\n",
    "    urllib.request.urlretrieve(url, dest)\n",
    "    size_mb = Path(dest).stat().st_size / 1e6\n",
    "    log.info(f\"{name} saved ({size_mb:.1f} MB)\")\n",
    "\n",
    "download(cfg.YUNET_URL,  cfg.YUNET_PATH,  \"YuNet detector\")\n",
    "download(cfg.SFACE_URL,  cfg.SFACE_PATH,  \"SFace recogniser\")\n",
    "\n",
    "print(\"✅  Both ONNX models ready\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 6 — FaceDetector  (YuNet wrapper with Haar fallback)\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "class FaceDetector:\n",
    "    \"\"\"\n",
    "    Detects faces in a BGR image.\n",
    "    Returns a list of dicts:\n",
    "        { box: [x,y,w,h], landmarks: np.ndarray(5,2) or None, score: float }\n",
    "\n",
    "    YuNet is used first. If it finds nothing, Haar Cascade is the fallback.\n",
    "    YuNet returns 5 landmarks: right_eye, left_eye, nose, right_mouth, left_mouth.\n",
    "    \"\"\"\n",
    "\n",
    "    _HAAR_URL  = \"https://github.com/opencv/opencv/raw/master/data/haarcascades/haarcascade_frontalface_default.xml\"\n",
    "    _HAAR_PATH = \"/content/haarcascade.xml\"\n",
    "\n",
    "    def __init__(self, yunet_path: str, conf: float = 0.85, nms: float = 0.3):\n",
    "        # YuNet — primary\n",
    "        self._yunet = cv2.FaceDetectorYN.create(\n",
    "            model           = yunet_path,\n",
    "            config          = \"\",\n",
    "            input_size      = (320, 320),\n",
    "            score_threshold = conf,\n",
    "            nms_threshold   = nms,\n",
    "            top_k           = 5\n",
    "        )\n",
    "        # Haar — fallback\n",
    "        download(self._HAAR_URL, self._HAAR_PATH, \"Haar Cascade\")\n",
    "        self._haar = cv2.CascadeClassifier(self._HAAR_PATH)\n",
    "        log.info(\"FaceDetector ready  (YuNet primary, Haar fallback)\")\n",
    "\n",
    "    def detect(self, bgr: np.ndarray) -> list:\n",
    "        results = self._yunet_detect(bgr)\n",
    "        if not results:\n",
    "            results = self._haar_detect(bgr)\n",
    "            if results:\n",
    "                log.debug(\"YuNet found nothing — using Haar fallback\")\n",
    "        return results\n",
    "\n",
    "    def _yunet_detect(self, bgr: np.ndarray) -> list:\n",
    "        h, w = bgr.shape[:2]\n",
    "        self._yunet.setInputSize((w, h))\n",
    "        _, faces = self._yunet.detect(bgr)\n",
    "        if faces is None:\n",
    "            return []\n",
    "        out = []\n",
    "        for f in faces:\n",
    "            box = f[:4].astype(int).tolist()\n",
    "            lm  = f[4:14].reshape(5, 2)          # 5 (x,y) pairs\n",
    "            out.append({\"box\": box, \"landmarks\": lm, \"score\": float(f[14])})\n",
    "        return out\n",
    "\n",
    "    def _haar_detect(self, bgr: np.ndarray) -> list:\n",
    "        gray  = cv2.cvtColor(bgr, cv2.COLOR_BGR2GRAY)\n",
    "        rects = self._haar.detectMultiScale(\n",
    "            gray, scaleFactor=1.1, minNeighbors=5, minSize=(60, 60))\n",
    "        return [\n",
    "            {\"box\": r.tolist(), \"landmarks\": None, \"score\": 1.0}\n",
    "            for r in rects\n",
    "        ]\n",
    "\n",
    "\n",
    "detector = FaceDetector(cfg.YUNET_PATH, cfg.DETECT_CONF, cfg.NMS_THRESHOLD)\n",
    "print(\"✅  FaceDetector initialised\")"
   ]
  },
  {
   "cell_type": "code",
