   "metadata": {},
   "outputs": [],
   "source": [
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "# CELL 9 — FaceGallery  (embedding store + nearest-neighbour search)\n",
    "#\n",
    "# The gallery stores one average embedding per person, computed from\n",
    "# all their registered photos (+ augmented variants).\n",
    "# Averaging reduces the effect of individual photo noise.\n",
    "# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n",
    "class FaceGallery:\n",
    "    \"\"\"\n",
    "    Stores averaged face embeddings for each known person.\n",
    "\n",
    "    Internally keeps:\n",
    "        self._names       : list of person names  (len = N)\n",
    "        self._embeddings  : np.ndarray (N, 128)   — one per person\n",
    "\n",
    "    Recognition = argmax cosine similarity, accepted if > threshold.\n",
    "    \"\"\"\n",
    "\n",
    "    def __init__(self, threshold: float = 0.363):\n",
    "        self._threshold   = threshold\n",
    "        self._names:       list        = []\n",
    "        self._embeddings:  np.ndarray  = np.empty((0, 128), dtype=np.float32)\n",
    "\n",
    "    # ── Registration ───────────────────────────────────────────────\n",
    "\n",
    "    def register(self, name: str, embeddings: list):\n",
    "        \"\"\"\n",
    "        Register or update a person.\n",
    "        embeddings: list of (128,) vectors (all photos for this person).\n",
    "        Their mean is stored.\n",
    "        \"\"\"\n",
    "        if not embeddings:\n",
    "            log.warning(f\"No embeddings for {name} — skipping.\")\n",
    "            return\n",
    "\n",
    "        mean_vec = np.mean(embeddings, axis=0).astype(np.float32)\n",
    "        # Re-normalise the mean\n",
    "        mean_vec /= (np.linalg.norm(mean_vec) + 1e-10)\n",
    "\n",
    "        if name in self._names:\n",
    "            # Update existing entry\n",
    "            idx = self._names.index(name)\n",
    "            self._embeddings[idx] = mean_vec\n",
    "            log.info(f\"Updated gallery entry for {name}\")\n",
    "        else:\n",
    "            self._names.append(name)\n",
    "            self._embeddings = np.vstack([self._embeddings, mean_vec])\n",
    "            log.info(f\"Registered {name}  (gallery size = {len(self._names)})\")\n",
    "\n",
    "    # ── Recognition ────────────────────────────────────────────────\n",
    "\n",
    "    def identify(self, query_vec: np.ndarray) -> dict:\n",
    "        \"\"\"\n",
    "        Returns:\n",
    "            name       : str or 'Unknown'\n",
    "            similarity : float  (cosine, 0–1)\n",
    "            confident  : bool\n",
    "        \"\"\"\n",
    "        if len(self._names) == 0:\n",
    "            return {\"name\": \"Unknown\", \"similarity\": 0.0, \"confident\": False}\n",
    "\n",
    "        # One cosine similarity per gallery entry\n",
    "        sims   = self._embeddings @ query_vec          # (N,) — fast dot product\n",
    "        best   = int(np.argmax(sims))\n",
    "        score  = float(sims[best])\n",
    "\n",
    "        if score >= self._threshold:\n",
    "            return {\"name\": self._names[best], \"similarity\": score, \"confident\": True}\n",
    "        return {\"name\": \"Unknown\", \"similarity\": score, \"confident\": False}\n",
    "\n",
    "    def identify_with_ranking(self, query_vec: np.ndarray, top_k: int = 3) -> list:\n",
    "        \"\"\"\n",
    "        Returns the top-k candidates as a list of dicts, sorted by similarity.\n",
    "        Useful for debugging / understanding borderline cases.\n",
    "        \"\"\"\n",
    "        if len(self._names) == 0:\n",
    "            return []\n",
    "        sims   = self._embeddings @ query_vec\n",
    "        ranked = np.argsort(sims)[::-1][:top_k]\n",
    "        return [\n",
    "            {\"name\": self._names[i], \"similarity\": float(sims[i])}\n",
    "            for i in ranked\n",
    "        ]\n",
    "\n",
    "    # ── Persistence ────────────────────────────────────────────────\n",
    "\n",
    "    def save(self, path: Path):\n",
    "        np.savez(str(path),\n",
    "                 names      = np.array(self._names),\n",
    "                 embeddings = self._embeddings)\n",
    "        log.info(f\"Gallery saved → {path}\")\n",
    "\n",
    "    def load(self, path: Path):\n",
    "        if not path.exists():\n",
    "            raise FileNotFoundError(f\"No saved gallery at {path}\")\n",
    "        data            = np.load(str(path), allow_pickle=True)\n",
    "        self._names     = data[\"names\"].tolist()\n",
    "        self._embeddings = data[\"embeddings\"]\n",
    "        log.info(f\"Gallery loaded from {path}  ({len(self._names)} people)\")\n",
    "\n",
    "    @property\n",
    "    def size(self) -> int:\n",
    "        return len(self._names)\n",
    "\n",
    "    @property\n",
    "    def names(self) -> list:\n",
    "        return list(self._names)\n",
    "\n",
    "\n",
    "gallery = FaceGallery(threshold=cfg.COSINE_THRESHOLD)\n",
    "print(\"✅  FaceGallery ready\")"
   ]
  },
